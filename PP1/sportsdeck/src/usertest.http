################################################### Sign in Test ###################################################

// Testing with existing account with correct information 
POST http://localhost:3000/api/auth/signin
Content-Type: application/json

{
    "email": "test1@test.com",
    "password": "password1"
}

### 

/// Sign in with wrong information should fail sign in 
POST http://localhost:3000/api/auth/signin
Content-Type: application/json

{
    "email": "invalid@test.com",
    "password": "asdfasdfasdf"
}

### Refresh Token
POST http://localhost:3000/api/auth/refresh
Content-Type: application/json

{
    "refreshToken": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6OSwiaWF0IjoxNzcxNTU1NTEyLCJleHAiOjE3NzIxNjAzMTJ9.6dkkDhdFI7MNThetBHgPMGIpkQq35fVFtYy9PeMaveE"
}


###

// successful signout
POST http://localhost:3000/api/auth/signout
Content-Type: application/json
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6OSwiZW1haWwiOiJ0ZXN0MUB0ZXN0LmNvbSIsInJvbGUiOiJVU0VSIiwiaWF0IjoxNzcxODEwNDY3LCJleHAiOjE3NzE4MTEzNjd9.OxuGP2kfg_e32stvfBta1tT68_fcCDZKncupTA-Du24

{
    "refreshToken": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6OSwiaWF0IjoxNzcxODEwMzc2LCJleHAiOjE3NzI0MTUxNzZ9.U3z41Tl9kMoNJvMbmgnFmYnfPcy9hfiXJEbALRWV2XA"
}

